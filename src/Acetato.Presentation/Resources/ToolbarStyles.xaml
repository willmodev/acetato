<!--
  Estilos de la barra flotante (HU-10). Solo tokens vía StaticResource; nada de
  colores hardcodeados. El acento teal marca ÚNICAMENTE el elemento activo.
  Depende de Tokens.xaml e Icons.xaml (merged antes en App.xaml).
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Botón de herramienta: 36px, radio 10, glass-on-hover, acento en disabled. -->
    <Style x:Key="ToolButton" TargetType="Button">
        <Setter Property="Width" Value="{StaticResource Size.Button}" />
        <Setter Property="Height" Value="{StaticResource Size.Button}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Fg.Resting}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Radius.Button}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Fill.Hover}" />
                            <Setter Property="Foreground" Value="{StaticResource Fg.Primary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Fill.Press}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource Fg.Disabled}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Glifo de icono: trazo de línea Lucide; el color sigue al Foreground del botón. -->
    <Style x:Key="ToolGlyph" TargetType="Path">
        <Setter Property="Stroke"
                Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="StrokeStartLineCap" Value="Round" />
        <Setter Property="StrokeEndLineCap" Value="Round" />
        <Setter Property="StrokeLineJoin" Value="Round" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Width" Value="{StaticResource Size.Icon}" />
        <Setter Property="Height" Value="{StaticResource Size.Icon}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!-- Grip de arrastre: puntos rellenos, discretos (fg-3). -->
    <Style x:Key="GripGlyph" TargetType="Path">
        <Setter Property="Fill" Value="{StaticResource Fg.Disabled}" />
        <Setter Property="Data" Value="{StaticResource Icon.Grip}" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="18" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Contenedor del grip: hit-testable (Background) y con cursor de movimiento. -->
    <Style x:Key="GripHandle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="{StaticResource Size.Button}" />
        <Setter Property="Cursor" Value="SizeAll" />
    </Style>

    <!-- Divisor entre grupos de botones. -->
    <Style x:Key="ToolDivider" TargetType="Rectangle">
        <Setter Property="Width" Value="1" />
        <Setter Property="Margin" Value="4,6" />
        <Setter Property="Fill" Value="{StaticResource Stroke.Divider}" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="RadiusX" Value="0.5" />
        <Setter Property="RadiusY" Value="0.5" />
    </Style>

    <!-- Superficie de popover: glass-strong, radio 14, sombra de elevación. -->
    <Style x:Key="PopoverSurface" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Chrome.GlassStrong}" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Popover}" />
        <Setter Property="BorderBrush" Value="{StaticResource Stroke.Outer}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="0,10,0,0" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="40" ShadowDepth="12" Direction="270" Opacity="0.52" Color="#FF000000" />
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
