<!--
  Acetato — tokens de diseño portados desde el design system
  (.claude/skills/acetato-design/colors_and_type.css).
  Color WPF = #AARRGGBB; el alfa codifica la opacidad de cada token.
  Dos paletas SEPARADAS: Chrome (UI) y Tintas (trazos). Nunca mezclar.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- ===================== CHROME — superficies glass ===================== -->
    <Color x:Key="Chrome.Glass.Color">#B816181C</Color>
    <Color x:Key="Chrome.GlassStrong.Color">#E0121417</Color>
    <Color x:Key="Chrome.GlassThin.Color">#8C1E2126</Color>
    <Color x:Key="Chrome.Solid.Color">#FF16181C</Color>
    <Color x:Key="Chrome.Solid2.Color">#FF1E2126</Color>

    <SolidColorBrush x:Key="Chrome.Glass" Color="{StaticResource Chrome.Glass.Color}" />
    <SolidColorBrush x:Key="Chrome.GlassStrong" Color="{StaticResource Chrome.GlassStrong.Color}" />
    <SolidColorBrush x:Key="Chrome.GlassThin" Color="{StaticResource Chrome.GlassThin.Color}" />
    <SolidColorBrush x:Key="Chrome.Solid" Color="{StaticResource Chrome.Solid.Color}" />
    <SolidColorBrush x:Key="Chrome.Solid2" Color="{StaticResource Chrome.Solid2.Color}" />

    <!-- ===================== CHROME — tinta neutra (fg) ===================== -->
    <SolidColorBrush x:Key="Fg.Primary" Color="#F5FFFFFF" />
    <SolidColorBrush x:Key="Fg.Resting" Color="#9EFFFFFF" />
    <SolidColorBrush x:Key="Fg.Disabled" Color="#61FFFFFF" />

    <!-- ===================== CHROME — hairlines / fills ===================== -->
    <SolidColorBrush x:Key="Stroke.Outer" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="Stroke.Divider" Color="#12FFFFFF" />
    <SolidColorBrush x:Key="Stroke.Highlight" Color="#24FFFFFF" />
    <SolidColorBrush x:Key="Fill.Hover" Color="#14FFFFFF" />
    <SolidColorBrush x:Key="Fill.Press" Color="#0AFFFFFF" />

    <!-- ===================== CHROME — acento (teal) ====================== -->
    <!-- Marca ÚNICAMENTE la herramienta activa. -->
    <Color x:Key="Accent.Color">#FF2FD9C4</Color>
    <SolidColorBrush x:Key="Accent" Color="{StaticResource Accent.Color}" />
    <SolidColorBrush x:Key="Accent.Quiet" Color="#FF1FA899" />
    <SolidColorBrush x:Key="Accent.Fill" Color="#292FD9C4" />
    <SolidColorBrush x:Key="Accent.Ring" Color="#732FD9C4" />
    <SolidColorBrush x:Key="Accent.Glow" Color="#4D2FD9C4" />
    <SolidColorBrush x:Key="Accent.Ink" Color="#FF0C1413" />
    <SolidColorBrush x:Key="Status.Danger" Color="#FFFF453A" />

    <!-- ===================== TINTAS — trazos de dibujo ==================== -->
    <Color x:Key="Ink.Red.Color">#FFFF3B30</Color>
    <Color x:Key="Ink.Blue.Color">#FF0A84FF</Color>
    <Color x:Key="Ink.Yellow.Color">#FFFFD60A</Color>
    <Color x:Key="Ink.Green.Color">#FF30D158</Color>
    <Color x:Key="Ink.White.Color">#FFFFFFFF</Color>
    <Color x:Key="Ink.Black.Color">#FF0A0A0A</Color>

    <SolidColorBrush x:Key="Ink.Red" Color="{StaticResource Ink.Red.Color}" />
    <SolidColorBrush x:Key="Ink.Blue" Color="{StaticResource Ink.Blue.Color}" />
    <SolidColorBrush x:Key="Ink.Yellow" Color="{StaticResource Ink.Yellow.Color}" />
    <SolidColorBrush x:Key="Ink.Green" Color="{StaticResource Ink.Green.Color}" />
    <SolidColorBrush x:Key="Ink.White" Color="{StaticResource Ink.White.Color}" />
    <SolidColorBrush x:Key="Ink.Black" Color="{StaticResource Ink.Black.Color}" />

    <!-- Halos para que un trazo sobreviva a fondos del mismo color -->
    <SolidColorBrush x:Key="Ink.Halo.Dark" Color="#59000000" />
    <SolidColorBrush x:Key="Ink.Halo.Light" Color="#73FFFFFF" />

    <!-- ===================== FORMA — radios ============================== -->
    <CornerRadius x:Key="Radius.Toolbar">16</CornerRadius>
    <CornerRadius x:Key="Radius.Button">10</CornerRadius>
    <CornerRadius x:Key="Radius.Popover">14</CornerRadius>
    <CornerRadius x:Key="Radius.Swatch">8</CornerRadius>

    <!-- ===================== TAMAÑOS de control ========================= -->
    <sys:Double x:Key="Size.Button">36</sys:Double>
    <sys:Double x:Key="Size.ButtonTouch">44</sys:Double>
    <sys:Double x:Key="Size.Icon">20</sys:Double>
    <sys:Double x:Key="Size.BarPadding">6</sys:Double>

    <!-- ===================== TIPOGRAFÍA ================================= -->
    <FontFamily x:Key="Font.Ui">Segoe UI Variable, Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Mono">Cascadia Code, Cascadia Mono, Consolas</FontFamily>

    <sys:Double x:Key="Text.Tooltip">12</sys:Double>
    <sys:Double x:Key="Text.Label">11</sys:Double>
    <sys:Double x:Key="Text.Kbd">11</sys:Double>
    <sys:Double x:Key="Text.Section">10</sys:Double>

    <!-- Anotaciones de texto (HU-13): familia de marca (Font.Ui) + peso legible
         sobre cualquier fondo. El color y el tamaño salen del estado de dibujo. -->
    <FontWeight x:Key="Annotation.FontWeight">SemiBold</FontWeight>

</ResourceDictionary>
